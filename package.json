  "license": "MIT",
  "peerDependencies": {
    "@nestjs/common": "^8.0.0 || ^9.0.0 || ^10.0.0 || ^11.0.0",
    "@nestjs/typeorm": "^8.0.0 || ^9.0.0 || ^10.0.0 || ^11.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0",
    "rxjs": "^7.0.0",
    "typeorm": "^0.3.0"
  },
  "dependencies": {
    "cron": "^4.4.0",
    "kafkajs": "^2.0.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/typeorm": "11.0.0",
    "@types/cron": "^2.0.1",
    "@types/node": "^20.0.0",
    "@types/uuid": "^10.0.0",
    "prettier": "^3.0.0",
    "typeorm": "0.3.20",
    "typescript": "^5.0.0"
  }
