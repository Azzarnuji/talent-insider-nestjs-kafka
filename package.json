{
  "name": "talent-insider-nestjs-kafka",
  "version": "1.0.0",
  "description": "NestJS Kafka module with agnostic Outbox Pattern support",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build"
  },
  "bin": {
